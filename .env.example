# -----------------------------------------------------------------------------
# Supabase PostgreSQL Connection Strings
# -----------------------------------------------------------------------------
# DATABASE_URL is used for connection pooling (PgBouncer) by Prisma Client.
# DIRECT_URL is used by Prisma CLI for migrations and introspection.
# -----------------------------------------------------------------------------

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres"

# Add other environment variables below if needed
